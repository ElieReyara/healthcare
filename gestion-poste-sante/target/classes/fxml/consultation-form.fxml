<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
FXML Formulaire Consultation (création/modification).
Controller : com.healthcenter.controller.ConsultationFormController
-->
<VBox xmlns="http://javafx.com/javafx/17" 
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.healthcenter.controller.ConsultationFormController"
      spacing="15" 
      style="-fx-padding: 20;"
      prefWidth="550"
      prefHeight="650">
    
    <!-- TITRE -->
    <Label fx:id="titleLabel" 
           text="Nouvelle Consultation" 
           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
    
    <Separator/>
    
    <!-- FORMULAIRE (GridPane 2 colonnes) -->
    <GridPane hgap="10" vgap="12">
        <columnConstraints>
            <ColumnConstraints minWidth="120" prefWidth="120"/>
            <ColumnConstraints minWidth="350" prefWidth="400"/>
        </columnConstraints>
        
        <!-- LIGNE 0 : PATIENT -->
        <Label text="Patient *" 
               GridPane.rowIndex="0" 
               GridPane.columnIndex="0"
               style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
        
        <ComboBox fx:id="patientCombo" 
                 GridPane.rowIndex="0" 
                 GridPane.columnIndex="1"
                 prefWidth="300"
                 promptText="Sélectionner un patient"/>

        <!-- LIGNE 1 : PERSONNEL -->
        <Label text="Personnel *" 
               GridPane.rowIndex="1" 
               GridPane.columnIndex="0"
               style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
        
        <ComboBox fx:id="personnelCombo" 
                 GridPane.rowIndex="1" 
                 GridPane.columnIndex="1"
                 prefWidth="300"
                 promptText="Sélectionner le personnel"/>
        
        <!-- LIGNE 1 : DATE CONSULTATION -->
        <Label text="Date *" 
               GridPane.rowIndex="2" 
               GridPane.columnIndex="0"
               style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
        
        <DatePicker fx:id="datePicker" 
                   GridPane.rowIndex="2" 
                   GridPane.columnIndex="1"
                   promptText="jj/mm/aaaa"
                   prefWidth="200"/>
        
        <!-- LIGNE 2 : HEURE -->
        <Label text="Heure *" 
               GridPane.rowIndex="3" 
               GridPane.columnIndex="0"
               style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
        
        <TextField fx:id="heureField" 
                  GridPane.rowIndex="3" 
                  GridPane.columnIndex="1"
                  promptText="HH:mm (ex: 14:30)"
                  prefWidth="120"/>
        
        <!-- LIGNE 3 : SYMPTÔMES -->
        <Label text="Symptômes" 
               GridPane.rowIndex="4" 
               GridPane.columnIndex="0"
               style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
        
        <VBox GridPane.rowIndex="4" GridPane.columnIndex="1" spacing="5">
            <TextArea fx:id="symptomesArea" 
                     promptText="Décrivez les symptômes rapportés par le patient..."
                     wrapText="true"
                     prefHeight="80"/>
            <Label text="Max 500 caractères" 
                   style="-fx-font-size: 10px; -fx-text-fill: #7f8c8d;"/>
        </VBox>
        
        <!-- LIGNE 4 : DIAGNOSTIC -->
        <Label text="Diagnostic" 
               GridPane.rowIndex="5" 
               GridPane.columnIndex="0"
               style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
        
        <VBox GridPane.rowIndex="5" GridPane.columnIndex="1" spacing="5">
            <TextArea fx:id="diagnosticArea" 
                     promptText="Diagnostic posé..."
                     wrapText="true"
                     prefHeight="80"/>
            <Label text="Max 500 caractères" 
                   style="-fx-font-size: 10px; -fx-text-fill: #7f8c8d;"/>
        </VBox>
        
        <!-- LIGNE 5 : PRESCRIPTION -->
        <Label text="Prescription" 
               GridPane.rowIndex="6" 
               GridPane.columnIndex="0"
               style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
        
        <VBox GridPane.rowIndex="6" GridPane.columnIndex="1" spacing="5">
            <TextArea fx:id="prescriptionArea" 
                     promptText="Prescription médicale (médicaments, posologie, durée...)..."
                     wrapText="true"
                     prefHeight="100"/>
            <Label text="Max 1000 caractères" 
                   style="-fx-font-size: 10px; -fx-text-fill: #7f8c8d;"/>
        </VBox>
    </GridPane>
    
    <!-- MESSAGE ERREUR -->
    <Label fx:id="errorLabel" 
           textFill="red" 
           wrapText="true" 
           visible="false"
           style="-fx-font-weight: bold; -fx-background-color: #ffe6e6; -fx-padding: 10; -fx-border-color: red; -fx-border-width: 1;"/>
    
    <!-- BOUTONS ACTION -->
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Annuler" 
               onAction="#handleCancel"
               style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-padding: 10 20; -fx-font-size: 14px;"/>
        
        <Button text="💾 Enregistrer" 
               onAction="#handleSave"
               defaultButton="true"
               style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-padding: 10 20; -fx-font-size: 14px; -fx-font-weight: bold;"/>
    </HBox>
    
</VBox>
