<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.healthcenter.controller.PersonnelFormController"
      spacing="15" prefWidth="600" prefHeight="700" stylesheets="@../styles.css">
    
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>
    
    <!-- Titre -->
    <HBox alignment="CENTER">
        <Label text="📝 FICHE PERSONNEL" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    </HBox>
    
    <Separator/>
    
    <!-- Formulaire -->
    <GridPane hgap="15" vgap="12">
        <columnConstraints>
            <ColumnConstraints minWidth="150" prefWidth="150"/>
            <ColumnConstraints minWidth="350" prefWidth="350" hgrow="ALWAYS"/>
        </columnConstraints>
        
        <!-- Ligne 0 : Nom -->
        <Label text="Nom * :" GridPane.columnIndex="0" GridPane.rowIndex="0">
            <font>
                <Font name="System Bold" size="12"/>
            </font>
        </Label>
        <TextField fx:id="nomField" promptText="Nom de famille" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        
        <!-- Ligne 1 : Prénom -->
        <Label text="Prénom * :" GridPane.columnIndex="0" GridPane.rowIndex="1">
            <font>
                <Font name="System Bold" size="12"/>
            </font>
        </Label>
        <TextField fx:id="prenomField" promptText="Prénom" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        
        <!-- Ligne 2 : Fonction -->
        <Label text="Fonction * :" GridPane.columnIndex="0" GridPane.rowIndex="2">
            <font>
                <Font name="System Bold" size="12"/>
            </font>
        </Label>
        <ComboBox fx:id="fonctionCombo" promptText="Sélectionnez une fonction" 
                  GridPane.columnIndex="1" GridPane.rowIndex="2" prefWidth="350"/>
        
        <!-- Ligne 3 : Spécialisation -->
        <Label text="Spécialisation :" GridPane.columnIndex="0" GridPane.rowIndex="3">
            <font>
                <Font name="System Bold" size="12"/>
            </font>
        </Label>
        <TextField fx:id="specialisationField" promptText="Ex: Pédiatre, Chirurgien..." 
                   GridPane.columnIndex="1" GridPane.rowIndex="3"/>
        
        <!-- Ligne 4 : Téléphone -->
        <Label text="Téléphone :" GridPane.columnIndex="0" GridPane.rowIndex="4">
            <font>
                <Font name="System Bold" size="12"/>
            </font>
        </Label>
        <TextField fx:id="telephoneField" promptText="Ex: 77 123 45 67 ou +221771234567" 
                   GridPane.columnIndex="1" GridPane.rowIndex="4"/>
        
        <!-- Ligne 5 : Email -->
        <Label text="Email :" GridPane.columnIndex="0" GridPane.rowIndex="5">
            <font>
                <Font name="System Bold" size="12"/>
            </font>
        </Label>
        <TextField fx:id="emailField" promptText="email@example.com" 
                   GridPane.columnIndex="1" GridPane.rowIndex="5"/>
        
        <!-- Ligne 6 : Adresse -->
        <Label text="Adresse :" GridPane.columnIndex="0" GridPane.rowIndex="6">
            <font>
                <Font name="System Bold" size="12"/>
            </font>
        </Label>
        <TextArea fx:id="adresseArea" promptText="Adresse complète..." 
                  prefRowCount="3" GridPane.columnIndex="1" GridPane.rowIndex="6"/>
        
        <!-- Ligne 7 : Numéro Matricule -->
        <Label text="N° Matricule :" GridPane.columnIndex="0" GridPane.rowIndex="7">
            <font>
                <Font name="System Bold" size="12"/>
            </font>
        </Label>
        <TextField fx:id="numeroMatriculeField" promptText="Ex: MAT-2024-001" 
                   GridPane.columnIndex="1" GridPane.rowIndex="7"/>
        
        <!-- Ligne 8 : Date Embauche -->
        <Label text="Date Embauche :" GridPane.columnIndex="0" GridPane.rowIndex="8">
            <font>
                <Font name="System Bold" size="12"/>
            </font>
        </Label>
        <DatePicker fx:id="dateEmbauchePicker" promptText="Sélectionnez une date" 
                    GridPane.columnIndex="1" GridPane.rowIndex="8" prefWidth="350"/>
        
        <!-- Ligne 9 : Actif -->
        <Label text="Statut :" GridPane.columnIndex="0" GridPane.rowIndex="9">
            <font>
                <Font name="System Bold" size="12"/>
            </font>
        </Label>
        <CheckBox fx:id="actifCheckbox" text="Actif" selected="true" 
                  GridPane.columnIndex="1" GridPane.rowIndex="9"/>
    </GridPane>
    
    <Separator/>
    
    <!-- Message erreur -->
    <Label fx:id="errorLabel" text="" style="-fx-text-fill: red; -fx-font-weight: bold;" wrapText="true"/>
    
    <!-- Légende champs requis -->
    <HBox spacing="5">
        <Label text="* Champs obligatoires" style="-fx-text-fill: gray; -fx-font-style: italic;"/>
    </HBox>
    
    <Region VBox.vgrow="ALWAYS"/>
    
    <!-- Boutons -->
    <HBox spacing="15" alignment="CENTER">
        <Button text="❌ Annuler" onAction="#handleCancel" prefWidth="150" 
                style="-fx-background-color: #9E9E9E; -fx-text-fill: white;">
            <font>
                <Font name="System Bold" size="13"/>
            </font>
        </Button>
        
        <Button text="💾 Enregistrer" onAction="#handleSave" prefWidth="150" 
                style="-fx-background-color: #4CAF50; -fx-text-fill: white;">
            <font>
                <Font name="System Bold" size="13"/>
            </font>
        </Button>
    </HBox>
    
</VBox>
