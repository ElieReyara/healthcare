<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.healthcenter.controller.UtilisateurController"
            prefHeight="650.0" prefWidth="1000.0">

    <top>
        <VBox spacing="10" style="-fx-background-color: #ecf0f1; -fx-padding: 15;">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Gestion des profils" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Actualiser" onAction="#handleRefresh" style="-fx-background-color: #95a5a6; -fx-text-fill: white;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <TableView fx:id="utilisateurTable">
            <BorderPane.margin>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </BorderPane.margin>
            <columns>
                <TableColumn fx:id="colUsername" text="Username" prefWidth="150"/>
                <TableColumn fx:id="colMatricule" text="Matricule" prefWidth="140"/>
                <TableColumn fx:id="colNomComplet" text="Nom complet" prefWidth="220"/>
                <TableColumn fx:id="colRole" text="Rôle" prefWidth="180"/>
                <TableColumn fx:id="colActif" text="Statut" prefWidth="120"/>
                <TableColumn fx:id="colDerniereConnexion" text="Dernière connexion" prefWidth="220"/>
            </columns>
            <placeholder>
                <Label text="Aucun profil utilisateur" style="-fx-text-fill: gray;"/>
            </placeholder>
        </TableView>
    </center>

    <bottom>
        <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 12; -fx-background-color: #ecf0f1;">
            <Button text="Nouveau profil" onAction="#handleNouveau" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;"/>
            <Button text="Activer" onAction="#handleActiver" style="-fx-background-color: #2ecc71; -fx-text-fill: white;"/>
            <Button text="Désactiver" onAction="#handleDesactiver" style="-fx-background-color: #e67e22; -fx-text-fill: white;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="infoLabel" text="Admin: gestion des profils" style="-fx-text-fill: #2c3e50;"/>
        </HBox>
    </bottom>

</BorderPane>
