<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.healthcenter.controller.StatistiquesDetailsController"
            style="-fx-background-color: #ecf0f1;">
    
    <!-- EN-TÊTE AVEC FILTRES -->
    <top>
        <VBox spacing="10" style="-fx-padding: 15; -fx-background-color: white;">
            <!-- Titre -->
            <Label text="📈 STATISTIQUES DÉTAILLÉES" 
                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            
            <!-- Filtres -->
            <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-padding: 10 0 0 0;">
                <Label text="Catégorie :" style="-fx-font-weight: bold;"/>
                <ComboBox fx:id="categorieCombo" prefWidth="200"/>
                
                <Label text="Période :" style="-fx-font-weight: bold;"/>
                <ComboBox fx:id="periodeCombo" prefWidth="150"/>
                
                <DatePicker fx:id="dateDebutPicker" prefWidth="140" promptText="Date début"/>
                <DatePicker fx:id="dateFinPicker" prefWidth="140" promptText="Date fin"/>
                
                <Button fx:id="btnAppliquer" text="▶️ Appliquer" onAction="#handleAppliquer"
                        style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 8 20;"/>
            </HBox>
        </VBox>
    </top>
    
    <!-- CONTENU PRINCIPAL -->
    <center>
        <TabPane fx:id="detailsTabPane" tabClosingPolicy="UNAVAILABLE" style="-fx-padding: 10;">
            
            <!-- ONGLET SYNTHÈSE -->
            <Tab fx:id="syntheseTab" text="📊 Synthèse">
                <ScrollPane fitToWidth="true" style="-fx-background-color: white;">
                    <VBox fx:id="syntheseContainer" spacing="10" style="-fx-padding: 20;">
                        <Label text="Sélectionnez une catégorie et cliquez sur Appliquer"
                               style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;"/>
                    </VBox>
                </ScrollPane>
            </Tab>
            
            <!-- ONGLET GRAPHIQUES -->
            <Tab fx:id="graphiquesTab" text="📉 Graphiques">
                <ScrollPane fitToWidth="true" style="-fx-background-color: white;">
                    <VBox fx:id="graphiquesContainer" spacing="15" style="-fx-padding: 20;">
                        <Label text="Les graphiques seront affichés ici"
                               style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;"/>
                    </VBox>
                </ScrollPane>
            </Tab>
            
            <!-- ONGLET DONNÉES DÉTAILLÉES -->
            <Tab fx:id="donneesTab" text="📋 Données Détaillées">
                <VBox style="-fx-padding: 10; -fx-background-color: white;">
                    <TableView fx:id="donneesTable" VBox.vgrow="ALWAYS">
                        <!-- Les colonnes seront ajoutées dynamiquement -->
                    </TableView>
                </VBox>
            </Tab>
            
        </TabPane>
    </center>
    
    <!-- PIED DE PAGE -->
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="10" style="-fx-padding: 10; -fx-background-color: white;">
            <Button text="💾 Exporter CSV"
                    style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 8 20;"/>
            <Button text="✖️ Fermer"
                    style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 8 20;"/>
        </HBox>
    </bottom>
    
</BorderPane>
