<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
FXML Menu Principal avec navigation entre modules.
Controller : com.healthcenter.controller.MainMenuController
-->
<BorderPane xmlns="http://javafx.com/javafx/17" 
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.healthcenter.controller.MainMenuController"
            stylesheets="@main-menu.css"
            prefHeight="750.0" 
            prefWidth="1200.0">
    
    <!-- TOP : Menu Bar -->
    <top>
        <VBox>
            <!-- Barre de menu -->
            <MenuBar style="-fx-background-color: #34495e;">
                
                <!-- Menu Session -->
                <Menu text="Session" style="-fx-text-fill: white;">
                    <MenuItem text="Déconnexion" onAction="#handleDeconnexion"/>
                </Menu>
                
                <!-- Menu Modules -->
                <Menu text="Modules" style="-fx-text-fill: white;">
                    <MenuItem text="Patients" onAction="#handlePatients"/>
                    <MenuItem text="Consultations" onAction="#handleConsultations"/>
                    <MenuItem text="Médicaments" onAction="#handleMedicaments"/>
                    <MenuItem text="Vaccinations" onAction="#handleVaccinations"/>
                    <MenuItem text="Personnel" onAction="#handlePersonnel"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="Statistiques" onAction="#handleStatistiques"/>
                    <MenuItem text="Rapports" onAction="#handleRapports"/>
                </Menu>
                
                <!-- Menu Aide -->
                <Menu text="Aide" style="-fx-text-fill: white;">
                    <MenuItem text="À propos" onAction="#handleAPropos"/>
                </Menu>
            </MenuBar>
            
            <!-- Header avec titre -->
            <HBox style="-fx-background-color: #2c3e50; -fx-padding: 15;">
                <Label text="HealthCare" 
                       style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;"/>
            </HBox>

            <HBox style="-fx-background-color: #ecf0f1; -fx-padding: 8 15 8 15;">
                <Label fx:id="currentModuleLabel" text="Module : Patients"
                       style="-fx-text-fill: #2c3e50; -fx-font-size: 14px; -fx-font-weight: bold;"/>
            </HBox>
        </VBox>
    </top>
    
    <!-- CENTER : Zone de contenu dynamique (modules chargés ici) -->
    <center>
        <BorderPane fx:id="contentPane">
            <!-- Le contenu des modules (patient-list.fxml, consultation-list.fxml, etc.) sera chargé ici dynamiquement -->
            <center>
                <VBox alignment="CENTER" spacing="20" style="-fx-background-color: #ecf0f1; -fx-padding: 50;">
                    <Label text="Bienvenue dans l'application HealthCare" 
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    
                    <Label text="Sélectionnez un module dans le menu ci-dessus pour commencer" 
                           style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;"/>
                    
                    <Separator prefWidth="400"/>
                    
                    <VBox spacing="10" alignment="CENTER">
                        <Label text="Modules disponibles :" 
                               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #34495e;"/>
                        
                        <Label text="✅ Patients - Gestion des dossiers patients" 
                               style="-fx-font-size: 14px;"/>
                        <Label text="✅ Consultations - Enregistrement des consultations médicales" 
                               style="-fx-font-size: 14px;"/>
                        <Label text="✅ Médicaments - Gestion du stock + alertes" 
                               style="-fx-font-size: 14px;"/>
                        <Label text="✅ Vaccinations - Calendrier vaccinal + Rappels" 
                               style="-fx-font-size: 14px;"/>
                        <Label text="✅ Personnel - Gestion du personnel médical" 
                               style="-fx-font-size: 14px;"/>
                        <Label text="✅ Statistiques - Tableaux de bord et analyses" 
                               style="-fx-font-size: 14px;"/>
                        <Label text="✅ Rapports - Génération PDF/Excel" 
                               style="-fx-font-size: 14px;"/>
                    </VBox>
                </VBox>
            </center>
        </BorderPane>
    </center>
    
    <!-- BOTTOM : Barre de statut -->
    <bottom>
        <HBox style="-fx-background-color: #34495e; -fx-padding: 10;" spacing="20">
            <Label text="2026" style="-fx-text-fill: white;"/>
            <Separator orientation="VERTICAL"/>
            <Label text="Système de Gestion de Santé" style="-fx-text-fill: white;"/>
            <Separator orientation="VERTICAL"/>
            <Label text="Spring Boot + JavaFX" style="-fx-text-fill: white;"/>
        </HBox>
    </bottom>
    
</BorderPane>
