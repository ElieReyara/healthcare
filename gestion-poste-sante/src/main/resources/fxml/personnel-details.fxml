<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.healthcenter.controller.PersonnelDetailsController"
      spacing="15" prefWidth="900" prefHeight="700" stylesheets="@../styles.css">
    
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>
    
    <!-- Titre + Infos Générales -->
    <VBox spacing="10">
        <HBox alignment="CENTER">
            <Label text="📋 FICHE DÉTAILLÉE PERSONNEL" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
        </HBox>
        
        <Separator/>
        
        <!-- Infos Générales (Grid 2 colonnes) -->
        <GridPane hgap="15" vgap="8">
            <columnConstraints>
                <ColumnConstraints minWidth="150" prefWidth="150"/>
                <ColumnConstraints minWidth="200" prefWidth="350" hgrow="ALWAYS"/>
                <ColumnConstraints minWidth="120" prefWidth="120"/>
                <ColumnConstraints minWidth="200" prefWidth="250" hgrow="ALWAYS"/>
            </columnConstraints>
            
            <!-- Ligne 0 -->
            <Label text="Nom complet :" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold;"/>
            <Label fx:id="nomCompletLabel" text="" GridPane.columnIndex="1" GridPane.rowIndex="0" style="-fx-font-size: 14px;"/>
            
            <Label text="Matricule :" GridPane.columnIndex="2" GridPane.rowIndex="0" style="-fx-font-weight: bold;"/>
            <Label fx:id="matriculeLabel" text="" GridPane.columnIndex="3" GridPane.rowIndex="0" style="-fx-font-size: 14px;"/>
            
            <!-- Ligne 1 -->
            <Label text="Fonction :" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold;"/>
            <Label fx:id="fonctionLabel" text="" GridPane.columnIndex="1" GridPane.rowIndex="1" style="-fx-font-size: 14px;"/>
            
            <Label text="Date Embauche :" GridPane.columnIndex="2" GridPane.rowIndex="1" style="-fx-font-weight: bold;"/>
            <Label fx:id="dateEmbaucheLabel" text="" GridPane.columnIndex="3" GridPane.rowIndex="1" style="-fx-font-size: 14px;"/>
            
            <!-- Ligne 2 -->
            <Label text="Spécialisation :" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: bold;"/>
            <Label fx:id="specialisationLabel" text="" GridPane.columnIndex="1" GridPane.rowIndex="2" style="-fx-font-size: 14px;"/>
            
            <!-- Ligne 3 -->
            <Label text="Contact :" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-font-weight: bold;"/>
            <Label fx:id="contactLabel" text="" GridPane.columnIndex="1" GridPane.rowIndex="3" GridPane.columnSpan="3" wrapText="true" style="-fx-font-size: 14px;"/>
        </GridPane>
    </VBox>
    
    <Separator/>
    
    <!-- TabPane 3 onglets -->
    <TabPane VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE">
        
        <!-- ONGLET 1 : Statistiques -->
        <Tab text="📊 Statistiques">
            <VBox spacing="20">
                <padding>
                    <Insets top="20" right="20" bottom="20" left="20"/>
                </padding>
                
                <Label text="Activité Consultations" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                
                <GridPane hgap="30" vgap="15">
                    <columnConstraints>
                        <ColumnConstraints minWidth="200" prefWidth="200"/>
                        <ColumnConstraints minWidth="100" prefWidth="100"/>
                    </columnConstraints>
                    
                    <Label text="Total consultations :" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-size: 14px;"/>
                    <Label fx:id="nbTotalConsultationsLabel" text="0" GridPane.columnIndex="1" GridPane.rowIndex="0" 
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2196F3;"/>
                    
                    <Label text="Consultations ce mois :" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-size: 14px;"/>
                    <Label fx:id="nbConsultationsMoisLabel" text="0" GridPane.columnIndex="1" GridPane.rowIndex="1" 
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #4CAF50;"/>
                    
                    <Label text="Consultations cette semaine :" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-size: 14px;"/>
                    <Label fx:id="nbConsultationsSemaineLabel" text="0" GridPane.columnIndex="1" GridPane.rowIndex="2" 
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #FF9800;"/>
                </GridPane>
                
                <Region VBox.vgrow="ALWAYS"/>
            </VBox>
        </Tab>
        
        <!-- ONGLET 2 : Planning -->
        <Tab text="📅 Planning Hebdomadaire">
            <VBox spacing="15">
                <padding>
                    <Insets top="20" right="20" bottom="20" left="20"/>
                </padding>
                
                <HBox spacing="15" alignment="CENTER_LEFT">
                    <Label text="Disponibilités par jour" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                    
                    <Region HBox.hgrow="ALWAYS"/>
                    
                    <Button text="✏️ Modifier Planning" onAction="#handleModifierPlanning" 
                            style="-fx-background-color: #2196F3; -fx-text-fill: white;">
                        <font>
                            <Font name="System Bold" size="12"/>
                        </font>
                    </Button>
                </HBox>
                
                <Separator/>
                
                <!-- GridPane pour afficher planning (7 lignes pour jours) -->
                <GridPane fx:id="planningGrid" hgap="20" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints minWidth="100" prefWidth="150"/>
                        <ColumnConstraints minWidth="200" prefWidth="500" hgrow="ALWAYS"/>
                    </columnConstraints>
                    
                    <padding>
                        <Insets top="10" left="20"/>
                    </padding>
                </GridPane>
                
                <Region VBox.vgrow="ALWAYS"/>
            </VBox>
        </Tab>
        
        <!-- ONGLET 3 : Historique Consultations -->
        <Tab text="📝 Historique Consultations">
            <VBox spacing="10">
                <padding>
                    <Insets top="15" right="15" bottom="15" left="15"/>
                </padding>
                
                <Label text="Dernières consultations effectuées" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                
                <TableView fx:id="consultationsTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colDate" text="Date" prefWidth="150" sortable="true"/>
                        <TableColumn fx:id="colPatient" text="Patient" prefWidth="250" sortable="true"/>
                        <TableColumn fx:id="colDiagnostic" text="Diagnostic" prefWidth="400" sortable="false"/>
                    </columns>
                    
                    <placeholder>
                        <Label text="Aucune consultation trouvée" style="-fx-text-fill: gray;"/>
                    </placeholder>
                </TableView>
            </VBox>
        </Tab>
        
    </TabPane>
    
    <!-- Bouton Fermer -->
    <HBox alignment="CENTER">
        <padding>
            <Insets top="10"/>
        </padding>
        
        <Button text="✖️ Fermer" onAction="#handleClose" prefWidth="150" 
                style="-fx-background-color: #9E9E9E; -fx-text-fill: white;">
            <font>
                <Font name="System Bold" size="13"/>
            </font>
        </Button>
    </HBox>
    
</VBox>
