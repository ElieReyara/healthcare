<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.healthcenter.controller.CarnetVaccinalController"
      spacing="15" style="-fx-padding: 20;" prefWidth="700" prefHeight="600">
    
    <!-- ========== TITRE ========== -->
    <HBox alignment="CENTER">
        <Label text="📋 CARNET VACCINAL"
               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1976D2;"/>
    </HBox>
    
    <Separator/>
    
    <!-- ========== INFOS PATIENT ========== -->
    <HBox spacing="20" alignment="CENTER_LEFT">
        <Label text="Patient :" style="-fx-font-weight: bold;"/>
        <Label fx:id="patientNomLabel" style="-fx-font-size: 16px;"/>
        
        <Region HBox.hgrow="ALWAYS"/>
        
        <Label text="Âge :" style="-fx-font-weight: bold;"/>
        <Label fx:id="patientAgeLabel" style="-fx-font-size: 16px;"/>
    </HBox>
    
    <Separator/>
    
    <!-- ========== TABLEAU CARNET ========== -->
    <TableView fx:id="carnetTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colVaccin" text="Vaccin" prefWidth="250" minWidth="250"/>
            <TableColumn fx:id="colStatut" text="Statut" prefWidth="150" minWidth="150"/>
            <TableColumn fx:id="colDateFait" text="Date Fait" prefWidth="130" minWidth="130"/>
            <TableColumn fx:id="colDateRappel" text="Date Rappel" prefWidth="130" minWidth="130"/>
        </columns>
        
        <placeholder>
            <VBox spacing="10" alignment="CENTER">
                <Label text="Aucune donnée de vaccination" 
                       style="-fx-text-fill: gray; -fx-font-style: italic;"/>
                <Label text="Le patient n'a encore reçu aucun vaccin." 
                       style="-fx-text-fill: gray; -fx-font-size: 12px;"/>
            </VBox>
        </placeholder>
    </TableView>
    
    <!-- ========== LÉGENDE ========== -->
    <HBox spacing="20" alignment="CENTER" style="-fx-padding: 10; -fx-background-color: #f5f5f5;">
        <Label text="✅ Fait" style="-fx-text-fill: green; -fx-font-weight: bold;"/>
        <Separator orientation="VERTICAL"/>
        <Label text="🔔 Rappel prévu" style="-fx-text-fill: orange; -fx-font-weight: bold;"/>
        <Separator orientation="VERTICAL"/>
        <Label text="⚠️ Rappel en retard" style="-fx-text-fill: red; -fx-font-weight: bold;"/>
        <Separator orientation="VERTICAL"/>
        <Label text="❌ Non fait" style="-fx-text-fill: red; -fx-font-weight: bold;"/>
        <Separator orientation="VERTICAL"/>
        <Label text="⏳ Pas encore requis" style="-fx-text-fill: gray; -fx-font-weight: bold;"/>
    </HBox>
    
    <!-- ========== BOUTONS ========== -->
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="🖨️ Imprimer" onAction="#handleImprimer"
                style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold;"/>
        
        <Button text="Fermer" onAction="#handleFermer"
                style="-fx-background-color: #9E9E9E; -fx-text-fill: white;"/>
    </HBox>
    
</VBox>
